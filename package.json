{
  "name": "aztec-watcher",
  "version": "0.1.0",
  "description": "npm package monitor for the Aztec Protocol ecosystem",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "aztec-watcher": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "watch:run": "node dist/cli/index.js run",
    "watch:init": "node dist/cli/index.js init",
    "watch:test": "node dist/cli/index.js test",
    "test": "vitest run"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.4"
  }
}
