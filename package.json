{
  "name": "aztec-watch",
  "version": "0.1.0",
  "description": "npm package monitor for the Aztec Protocol ecosystem",
  "type": "module",
  "engines": {
    "node": ">=22.5.0"
  },
  "bin": {
    "aztec-watch": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx --disable-warning=ExperimentalWarning src/cli/index.ts",
    "watch:run": "node --disable-warning=ExperimentalWarning dist/cli/index.js run",
    "watch:setup": "node --disable-warning=ExperimentalWarning dist/cli/index.js setup",
    "watch:test": "node --disable-warning=ExperimentalWarning dist/cli/index.js test"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
